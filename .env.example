# Copy this file to `.env` and fill in real values.
# `.env` is in .gitignore — never commit it.

# OpenTopography API key. OPTIONAL for the server: if set, the server uses
# this key as a fallback when a request arrives without one. In production /
# shared deployments, every visitor brings their own key via the UI instead,
# so leave this blank when deploying publicly. Useful only for local dev so
# you don't have to paste your key into the browser on every boot.
#
# Get a free key at: https://opentopography.org
OPENTOPO_KEY=
